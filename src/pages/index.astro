---
import { getCollection, render } from "astro:content";
import "../styles/global.css";

const trips = await getCollection("trips");
trips.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const renderedTrips = await Promise.all(
    trips.map(async (trip) => {
        const { Content } = await render(trip);
        return { trip, Content };
    }),
);
---

<html lang="en" class="dark">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>Moto Blog</title>
    </head>
    <body
        class="bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100 min-h-screen transition-colors duration-300"
    >
        <header class="max-w-4xl mx-auto px-6 py-12 text-center">
            <h1 class="text-8xl font-bold tracking-tight">St. Gabriel</h1>

            <p class="text-zinc-500 dark:text-zinc-400 mt-6 mb-8 text-lg">
                Weekend rides & open roads
            </p>
            <button
                id="theme-toggle"
                class="p-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-800 dark:text-zinc-100"
            >
                <!-- Sun icon (shown in dark mode) -->
                <svg
                    id="icon-sun"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-5 h-5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
                    ></path>
                </svg>
                <!-- Moon icon (shown in light mode) -->
                <svg
                    id="icon-moon"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-5 h-5 hidden"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
                    ></path>
                </svg>
            </button>
        </header>

        <main class="max-w-4xl mx-auto px-6 pb-16 space-y-16">
            {
                renderedTrips.map(({ trip, Content }) => (
                    <article class="border-t border-zinc-200 dark:border-zinc-800 pt-10">
                        {/* <h2 class="text-2xl font-semibold">
                            {trip.data.title}
                            {trip.data.date.toDateString()}
                        </h2>
                        <p class="text-zinc-400 dark:text-zinc-500 text-sm mt-1">
                            {trip.data.date.toDateString()}
                        </p>
                        <p class="text-zinc-700 dark:text-zinc-300 mt-4 leading-relaxed">
                            {trip.data.description}
                        </p>
                        <div class="text-zinc-700 dark:text-zinc-300 mt-4 leading-relaxed prose dark:prose-invert">
                            <Content />
                        </div> */}
                        <h2 class="text-2xl font-semibold">
                            {trip.data.title}
                        </h2>

                        <p class="text-zinc-500 dark:text-zinc-400 text-sm mt-1">
                            {trip.data.date.toLocaleDateString("en-GB")}
                            {trip.data.date_end &&
                                ` — ${trip.data.date_end.toLocaleDateString("en-GB")}`}
                        </p>

                        {(trip.data.distance || trip.data.elevation) && (
                            <div class="flex gap-4 mt-2 text-sm text-zinc-500 dark:text-zinc-400">
                                {trip.data.distance && (
                                    <span>📍 {trip.data.distance} km</span>
                                )}
                                {trip.data.elevation && (
                                    <span>⛰️ {trip.data.elevation} m</span>
                                )}
                            </div>
                        )}

                        <p class="text-zinc-700 dark:text-zinc-300 mt-4 leading-relaxed">
                            {trip.data.description}
                        </p>
                        {trip.data.photos && trip.data.photos.length > 0 && (
                            <div class="grid grid-cols-3 gap-2 mt-6">
                                {trip.data.photos.map((photo) => (
                                    <a
                                        href={photo}
                                        class="glightbox"
                                        data-gallery={trip.id}
                                    >
                                        <img
                                            src={photo}
                                            alt=""
                                            class="w-full h-48 object-cover rounded cursor-pointer"
                                        />
                                    </a>
                                ))}
                            </div>
                        )}

                        {trip.data.youtube && (
                            <div class="mt-6 aspect-video">
                                <iframe
                                    src={`https://www.youtube.com/embed/${trip.data.youtube}`}
                                    class="w-full h-full rounded"
                                    allowfullscreen
                                />
                            </div>
                        )}
                    </article>
                ))
            }
        </main>

        <script>
            import GLightbox from "glightbox";
            import "glightbox/dist/css/glightbox.css";

            //Theme toggle logic
            const html = document.documentElement;
            const btn = document.getElementById("theme-toggle");
            const iconSun = document.getElementById("icon-sun");
            const iconMoon = document.getElementById("icon-moon");

            const saved = localStorage.getItem("theme");
            if (saved === "light") {
                html.classList.remove("dark");
                iconSun?.classList.add("hidden");
                iconMoon?.classList.remove("hidden");
            }

            btn!.addEventListener("click", () => {
                const isDark = html.classList.toggle("dark");
                iconSun?.classList.toggle("hidden", !isDark);
                iconMoon?.classList.toggle("hidden", isDark);
                localStorage.setItem("theme", isDark ? "dark" : "light");
            });

            // Lightbox gallery initialization
            GLightbox({
                selector: ".glightbox",
            });

            import NetlifyIdentity from "netlify-identity-widget";
            NetlifyIdentity.on("login", () => {
                document.location.href = "/admin/";
            });
            NetlifyIdentity.init();
        </script>
    </body>
</html>
